{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.ics",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/calendar; charset=utf-8"
          }
        ]
      }
    ]
  }
}